# ── CleverTap Credentials ─────────────────────────────────────────────────────
# Find these in CleverTap → Settings → API Credentials
CLEVERTAP_ACCOUNT_ID=your_account_id_here
CLEVERTAP_PASSCODE=your_passcode_here

# ── CleverTap Browser Login (for ct_browser_sync.py) ──────────────────────────
CT_LOGIN_EMAIL=your_login_email@example.com
CT_LOGIN_PASSWORD=your_login_password
CT_HEADLESS=true              # set to false to watch the browser (useful for debugging)
CT_FROM_DATE=                 # e.g. 18/3/2026 — leave blank to default to yesterday
CT_TO_DATE=                   # e.g. 19/3/2026 — leave blank to default to today

# CleverTap region: in1 (India), eu1 (Europe), us1 (US), sg1 (Singapore), sk1 (SKU)
CLEVERTAP_REGION=in1

# Only sync campaigns created by this user
FILTER_CREATOR=shivamprashar@goodeducator.com

# ── Google Sheets ─────────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_JSON=credentials.json
SPREADSHEET_ID=14pD2SxmPGqn74-7_yyq93Ocp1xa8QI9nOTSnRWS2Xi4
WORKSHEET_GID=470166044

# ── Schedule ──────────────────────────────────────────────────────────────────
# Time for daily sync (24-hour format)
DAILY_SYNC_TIME=08:00

# Poll for updates every N minutes (0 = disabled)
POLL_INTERVAL_MINUTES=60
